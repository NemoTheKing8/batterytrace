---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="batterytrace — Power Bank Environmental Impact Calculator" description="Select a Cuktech power bank to estimate metal leakage, carbon footprint, and ecotoxicity from production to disposal.">

  <div class="home-hero">
    <div class="home-hero-bg">
      <img src="/images/hero-intro.jpg" alt="Power banks collection" />
    </div>
    <div class="home-hero-inner">
      <div class="home-hero-text">
        <h1 class="home-hero-title">What does your<br>power bank leave behind?</h1>
        <p class="home-hero-sub">Teardown. Analysis. Estimation — the environmental cost of every power bank, from production to disposal.</p>
        <div class="home-hero-actions">
          <a href="/calculator" class="home-hero-cta">Start Calculating</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  .home-hero {
    position: fixed;
    inset: 0;
    overflow: hidden;
  }
  .home-hero-bg {
    position: absolute;
    inset: 0;
  }
  .home-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: ken-burns 24s ease-out forwards;
  }
  @keyframes ken-burns {
    0% { transform: scale(1); }
    100% { transform: scale(1.06); }
  }
  .home-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, oklch(6.5% 0.01 165 / 0.8) 0%, transparent 40%, transparent 60%, oklch(6.5% 0.01 165 / 0.9) 100%);
  }
  .home-hero-inner {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    align-items: flex-end;
    padding: 0 clamp(32px, 6vw, 100px) clamp(80px, 12vh, 140px);
  }
  .home-hero-text {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 600px;
  }
  .home-hero-title {
    font-size: clamp(48px, 6vw, 80px);
    font-weight: 300;
    line-height: 1.06;
    margin: 0;
    color: #fff;
    letter-spacing: -0.02em;
    text-wrap: balance;
    animation: fade-up 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .home-hero-sub {
    font-size: 18px;
    color: rgba(255,255,255,0.55);
    margin: 0;
    line-height: 1.7;
    max-width: 460px;
    font-weight: 350;
    animation: fade-up 0.9s 0.2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .home-hero-actions {
    display: flex;
    gap: 12px;
    margin-top: 8px;
    animation: fade-up 0.9s 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes fade-up {
    0% { opacity: 0; transform: translateY(24px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .home-hero-cta {
    display: inline-block;
    padding: 16px 40px;
    background: rgba(255,255,255,0.1);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 6px;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .home-hero-cta:hover {
    background: rgba(255,255,255,0.18);
    border-color: rgba(255,255,255,0.35);
  }

  @media (prefers-reduced-motion: reduce) {
    .home-hero-bg img { animation: none; }
    .home-hero-title,
    .home-hero-sub,
    .home-hero-actions { animation: none; }
  }

  @media (max-width: 680px) {
    .home-hero-title { font-size: 36px; }
    .home-hero-sub { font-size: 15px; }
    .home-hero-inner { padding: 0 24px 60px; }
    .home-hero-cta { padding: 14px 32px; font-size: 15px; }
  }
</style>
