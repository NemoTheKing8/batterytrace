</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const checkboxes = document.querySelectorAll('.ps-checkbox') as NodeListOf<HTMLInputElement>;
    const selectedList = document.getElementById('selected-items')!;
    const calcStatus = document.getElementById('calc-status')!;
    const calcTotalBar = document.getElementById('calc-total-bar')!;
    const clearBtn = document.getElementById('calc-clear')!;

    // Totals elements — landfill
    const sumCoL = document.getElementById('sum-co-landfill')!;
    const sumLiL = document.getElementById('sum-li-landfill')!;
    const sumNiL = document.getElementById('sum-ni-landfill')!;
    const sumMnL = document.getElementById('sum-mn-landfill')!;
    // Totals elements — recycle
    const sumCoR = document.getElementById('sum-co-recycle')!;
    const sumLiR = document.getElementById('sum-li-recycle')!;
    const sumNiR = document.getElementById('sum-ni-recycle')!;
    const sumMnR = document.getElementById('sum-mn-recycle')!;
    // Carbon & water (same both scenarios)
    const sumCarbon = document.getElementById('sum-carbon')!;
    const sumCarbonR = document.getElementById('sum-carbon-r')!;
    const sumCtue = document.getElementById('sum-ctue')!;
    const sumCtueR = document.getElementById('sum-ctue-r')!;
    const goldfishCount = document.getElementById('goldfish-count')!;

    // State
    const selected = new Map<string, number>();

    // Product metadata (from data attributes)
    const productMeta = new Map<string, { name: string; spec: string; co: number; li: number; ni: number; mn: number; carbon: number; water: number; recovery: number; carbonLf: number; carbonRc: number; waterLf: number; waterRc: number; ctueLf: number; ctueRc: number }>();

    checkboxes.forEach(cb => {
      const id = cb.value;
      productMeta.set(id, {
        name: cb.closest('.ps-card')?.querySelector('.ps-card-name')?.textContent || id,
        spec: cb.closest('.ps-card')?.querySelector('.ps-card-specs')?.textContent || '',
        co: parseFloat(cb.dataset.co || '0'),
        li: parseFloat(cb.dataset.li || '0'),
        ni: parseFloat(cb.dataset.ni || '0'),
        mn: parseFloat(cb.dataset.mn || '0'),
        carbon: parseFloat(cb.dataset.carbon || '0'),
        water: parseFloat(cb.dataset.water || '0'),
        recovery: parseFloat(cb.dataset.recovery || '0.95'),
        carbonLf: parseFloat(cb.dataset.carbonLf || '0.3'),
        carbonRc: parseFloat(cb.dataset.carbonRc || '0.15'),
        waterLf: parseFloat(cb.dataset.waterLf || '20'),
        waterRc: parseFloat(cb.dataset.waterRc || '10'),
        ctueLf: parseFloat(cb.dataset.ctueLf || '6.2'),
        ctueRc: parseFloat(cb.dataset.ctueRc || '0.31'),
      });
    });

    const calcEmpty = document.getElementById('calc-empty')!;
    const calcResults = document.getElementById('calc-results')!;

    function render() {
      if (selected.size === 0) {
        selectedList.innerHTML = '';
        calcStatus.textContent = '尚未选择';
        calcTotalBar.style.display = 'none';
        calcEmpty.style.display = '';
        calcResults.style.display = 'none';
      } else {
        calcStatus.textContent = `${selected.size} 款`;
        calcTotalBar.style.display = 'flex';
        calcEmpty.style.display = 'none';
        calcResults.style.display = '';
        let html = '';
        selected.forEach((qty, id) => {
          const m = productMeta.get(id);
          if (!m) return;
          html += `
            <div class="calc-sel-item">
              <div class="calc-sel-name">${m.name}</div>
              <div class="calc-sel-qty">
                <button data-action="dec" data-id="${id}">−</button>
                <span class="calc-sel-qty-val">${qty}</span>
                <button data-action="inc" data-id="${id}">+</button>
              </div>
              <button class="calc-sel-remove" data-action="remove" data-id="${id}" title="移除">×</button>
            </div>`;
        });
        selectedList.innerHTML = html;
      }
      updateTotals();
    }

    function updateTotals() {
      let co = 0, li = 0, ni = 0, mn = 0;
      let coR = 0, liR = 0, niR = 0, mnR = 0;
      let carbonLf = 0, waterLf = 0, ctueLf = 0;
      let carbonRc = 0, waterRc = 0, ctueRc = 0;
      selected.forEach((qty, id) => {
        const m = productMeta.get(id);
        if (!m) return;
        // Metals
        co += m.co * qty;
        li += m.li * qty;
        ni += m.ni * qty;
        mn += m.mn * qty;
        coR += m.co * (1 - m.recovery) * qty;
        liR += m.li * (1 - m.recovery) * qty;
        niR += m.ni * (1 - m.recovery) * qty;
        mnR += m.mn * (1 - m.recovery) * qty;
        // Carbon = production + disposal
        carbonLf += (m.carbon + m.carbonLf) * qty;
        carbonRc += (m.carbon + m.carbonRc) * qty;
        // Water = production + disposal
        waterLf += (m.water + m.waterLf) * qty;
        waterRc += (m.water + m.waterRc) * qty;
        ctueLf += m.ctueLf * qty;
        ctueRc += m.ctueRc * qty;
      });
      // Landfill
      sumCoL.textContent = co.toFixed(1);
      sumLiL.textContent = li.toFixed(1);
      sumNiL.textContent = ni.toFixed(1);
      sumMnL.textContent = mn.toFixed(1);
      sumCarbon.textContent = carbonLf.toFixed(1);
      // Recycle
      sumCoR.textContent = coR.toFixed(2);
      sumLiR.textContent = liR.toFixed(2);
      sumNiR.textContent = niR.toFixed(2);
      sumMnR.textContent = mnR.toFixed(2);
      sumCarbonR.textContent = carbonRc.toFixed(1);
      sumCtue.textContent = ctueLf.toFixed(1);
      sumCtueR.textContent = ctueRc.toFixed(2);
      goldfishCount.textContent = Math.round(ctueLf / 0.04).toString();

      // Animate pulse
      [sumCoL, sumLiL, sumNiL, sumMnL, sumCoR, sumLiR, sumNiR, sumMnR, sumCarbon, sumCarbonR, sumCtue, sumCtueR].forEach(el => {
        el.classList.remove('pulse');
        void (el as HTMLElement).offsetWidth;
        el.classList.add('pulse');
      });
    }

    // Checkbox → add/remove from selected
    checkboxes.forEach(cb => {
      cb.addEventListener('change', () => {
        if (cb.checked) {
          selected.set(cb.value, 1);
        } else {
          selected.delete(cb.value);
        }
        render();
      });
    });

    // Delegate clicks on selected items (qty +/-, remove)
    selectedList.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button') as HTMLButtonElement | null;
      if (!btn) return;
      const action = btn.dataset.action;
      const id = btn.dataset.id;
      if (!action || !id) return;

      if (action === 'inc') {
        selected.set(id, (selected.get(id) || 1) + 1);
      } else if (action === 'dec') {
        const qty = selected.get(id) || 1;
        if (qty <= 1) {
          selected.delete(id);
          // Uncheck the corresponding checkbox
          const cb = document.querySelector(`.ps-checkbox[value="${id}"]`) as HTMLInputElement;
          if (cb) cb.checked = false;
        } else {
          selected.set(id, qty - 1);
        }
      } else if (action === 'remove') {
        selected.delete(id);
        const cb = document.querySelector(`.ps-checkbox[value="${id}"]`) as HTMLInputElement;
        if (cb) cb.checked = false;
      }
      render();
    });

    // Clear all
    clearBtn.addEventListener('click', () => {
      selected.clear();
      checkboxes.forEach(cb => { cb.checked = false; });
      render();
    });

    render();

    // Learn More → full-screen modal
    const modal = document.getElementById('learn-modal')!;
    const modalTitle = document.getElementById('modal-title')!;
    const modalBody = document.getElementById('modal-body')!;
    const modalClose = document.getElementById('modal-close')!;

    function openModal(btn: HTMLElement) {
      const name = btn.dataset.name || '产品';
      const bomJson = btn.dataset.bom || '[]';
      const bom = JSON.parse(bomJson);

      let bomHtml = '';
      if (bom.length > 0) {
        const rows = bom.map((r: any) =>
          `<tr><td>${r.cat}</td><td>${r.fn}</td><td>${r.brand||'—'}</td><td>${r.spec}</td><td>${r.pkg}</td><td>${r.qty}</td></tr>`
        ).join('');
        bomHtml = `
          <div class="bom-section">
            <div class="bom-title">物料清单</div>
            <div class="bom-table-wrap">
              <table class="bom-table">
                <thead><tr><th>类型</th><th>功能</th><th>品牌</th><th>规格</th><th>封装</th><th>数量</th></tr></thead>
                <tbody>${rows}</tbody>
              </table>
            </div>
          </div>`;
      }

      modalTitle.textContent = `${name} — 物料清单`;
      modalBody.innerHTML = (bom.length === 0)
        ? '<div style="color:#666;text-align:center;padding:40px;">暂无物料数据</div>'
        : bomHtml;
      modal.hidden = false;
    }

    function closeModal() {
      modal.hidden = true;
    }

    document.querySelectorAll('.ps-learn-btn').forEach(btn => {
      btn.addEventListener('click', () => openModal(btn as HTMLElement));
    });
    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });
  });
</script>
