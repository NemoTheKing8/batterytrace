<BaseLayout title="充电宝环境影响计算器" description="选择酷态科充电宝产品，估算从制造到废弃的金属流失、碳足迹与生态毒性。">

  <!-- ═══ Hero + Calculator ═══ -->
  <div class="calc-hero">
    <div class="hero-bg">
      <img src={heroBg.src} alt="" />
    </div>
    <div class="calc-hero-inner">
      <div class="hero-grid">
        <div class="hero-text">
          <h1 class="calc-hero-title">充电宝环境影响计算器</h1>
          <p class="calc-hero-sub">选择产品，查看从制造到废弃产生的金属流失、碳足迹与生态毒性影响。</p>
          <div class="hero-actions">
            <a href="#product-list" class="hero-cta">开始选择产品</a>
            <a href="/reference" class="hero-cta-secondary">查看计算依据</a>
          </div>
        </div>
        <div class="calc-panel" id="calc-panel">
          <div class="calc-selected-header">
            <span>已选商品</span>
            <span class="calc-selected-count" id="calc-status">尚未选择</span>
          </div>
          <div class="calc-selected-list" id="selected-items">
            <div class="calc-empty-state" id="calc-empty">
              <div class="calc-empty-icon">0</div>
              <div class="calc-empty-title">请选择充电宝产品</div>
              <div class="calc-empty-desc">勾选下方产品后，将在此处显示未规范回收与规范回收两种情景的环境影响估算结果。</div>
            </div>
          </div>
          <div id="calc-results" style="display:none;">
            <div class="calc-divider" style="margin-top:0;"></div>
            <div class="scenario-cards">
              <!-- Landfill -->
              <div class="scenario-card landfill">
                <div class="scenario-card-title">未规范回收</div>
                <div class="calc-row-inner">
                  <div class="calc-item-small">
                    <div class="calc-value" id="sum-co-landfill">0</div>
                    <div class="calc-label">钴 Co (g)</div>
                  </div>
                  <div class="calc-item-small">
                    <div class="calc-value" id="sum-li-landfill">0</div>
                    <div class="calc-label">锂 Li (g)</div>
                  </div>
                  <div class="calc-item-small">
                    <div class="calc-value" id="sum-ni-landfill">0</div>
                    <div class="calc-label">镍 Ni (g)</div>
                  </div>
                  <div class="calc-item-small">
                    <div class="calc-value" id="sum-mn-landfill">0</div>
                    <div class="calc-label">锰 Mn (g)</div>
                  </div>
                </div>
                <div class="calc-row-inner primary-row">
                  <div class="calc-item-small primary">
                    <div class="calc-value" id="sum-carbon">0</div>
                    <div class="calc-label">碳足迹 (kg CO₂eq)</div>
                  </div>
                  <div class="calc-item-small primary">
                    <div class="calc-value" id="sum-ctue">0</div>
                    <div class="calc-label ctue-label">
                      生态毒性 CTUe
                      <span class="ctue-tooltip">≈ <span id="goldfish-count">0</span> 个金鱼缸 (40L)</span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Recycle -->
              <div class="scenario-card recycle">
                <div class="scenario-card-title">规范回收</div>
                <div class="calc-row-inner">
                  <div class="calc-item-small">
                    <div class="calc-value recycled" id="sum-co-recycle">0</div>
                    <div class="calc-label">钴 Co (g)</div>
                  </div>
                  <div class="calc-item-small">
                    <div class="calc-value recycled" id="sum-li-recycle">0</div>
                    <div class="calc-label">锂 Li (g)</div>
                  </div>
                  <div class="calc-item-small">
                    <div class="calc-value recycled" id="sum-ni-recycle">0</div>
                    <div class="calc-label">镍 Ni (g)</div>
                  </div>
                  <div class="calc-item-small">
                    <div class="calc-value recycled" id="sum-mn-recycle">0</div>
                    <div class="calc-label">锰 Mn (g)</div>
                  </div>
                </div>
                <div class="calc-row-inner primary-row">
                  <div class="calc-item-small primary">
                    <div class="calc-value" id="sum-carbon-r">0</div>
                    <div class="calc-label">碳足迹 (kg CO₂eq)</div>
                  </div>
                  <div class="calc-item-small primary">
                    <div class="calc-value" id="sum-ctue-r">0</div>
                    <div class="calc-label">生态毒性 CTUe</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="calc-total-bar" id="calc-total-bar" style="display:none;">
              <button class="calc-clear-btn" id="calc-clear">清空全部</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="page-container" style="padding-top: 0;">

    <!-- ═══ Brand Section (一级窗口) ═══ -->
    <section class="brand-section">
      <div class="brand-section-header">
        <h2 class="brand-section-title">{brand.name} <span class="brand-section-en">{brand.name_en}</span></h2>
      </div>

      <!-- Product selection cards -->
      <div class="product-select-grid" id="product-list">
        {catalog.map((item, i) => {
          return (
            <div class="ps-card" data-index={i}>
              <label class="ps-image-btn">
                <input type="checkbox" class="ps-checkbox" value={item.product.id}
                  data-co={item.metrics.cobalt_g}
                  data-li={item.metrics.lithium_g}
                  data-ni={item.metrics.nickel_g}
                  data-mn={item.metrics.manganese_g}
                  data-carbon={item.metrics.carbon_kg_co2eq}
                  data-water={item.metrics.water_liters}
                  data-recovery={item.metrics.recovery_rate ?? 0.95}
                  data-carbon-lf={item.metrics.carbon_disposal_landfill ?? 0.3}
                  data-carbon-rc={item.metrics.carbon_disposal_recycle ?? 0.15}
                  data-water-lf={item.metrics.water_disposal_landfill ?? 20}
                  data-water-rc={item.metrics.water_disposal_recycle ?? 10}
                  data-ctue-lf={item.metrics.ctue_landfill ?? 6.2}
                  data-ctue-rc={item.metrics.ctue_recycle ?? 0.31}
                />
                <div class="ps-img-box">
                  <img src={item.product.image} alt={item.product.name} class="ps-img" loading="lazy" />
                  <div class="ps-check-badge">✓</div>
                </div>
              </label>
              <div class="ps-card-info">
                <div class="ps-card-name">{item.product.name}</div>
                <div class="ps-card-specs">{item.product.capacity_mah.toLocaleString()}mAh · {item.product.power_w}W · {item.product.weight_g}g · ¥{item.product.price_cny}</div>
                <div class="ps-card-pills">
                  <span class="ps-pill carbon">碳 {item.metrics.carbon_kg_co2eq} kg</span>
                  <span class="ps-pill water">水 {item.metrics.water_liters} L</span>
                  <span class="ps-pill metal">金属 {(item.metrics.cobalt_g + item.metrics.nickel_g + item.metrics.lithium_g + item.metrics.manganese_g).toFixed(1)}g</span>
                </div>
              </div>
              <button class="ps-learn-btn" type="button" data-bom={JSON.stringify(productBom[item.product.id] || [])} data-name={item.product.name}>
                物料清单 ▸
              </button>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Disclaimer -->
    <div class="disclaimer-bar" style="margin-top: 32px;">
      <div class="disclaimer">
        <strong>估算数据，非品牌实测。</strong> 以上数字基于已发表学术文献及充电头网拆解报告中对电芯型号、材料的分析做出的最佳近似。酷态科未提供或认可这些数据。组件污染来源信息基于拆解报告的物料清单推断。
      </div>
    </div>

    <div class="methodology">
      <a href="/reference" class="ref-link">Data sources, methods & references →</a>
    </div>

    <!-- Full-screen modal for 了解更多 -->
    <div class="modal-overlay" id="learn-modal" hidden>
      <div class="modal-panel">
        <div class="modal-header">
          <h3 class="modal-title" id="modal-title">充电宝内部的污染来源</h3>
          <button class="modal-close" id="modal-close">✕</button>
        </div>
        <div class="modal-body" id="modal-body"></div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Global Glow ── */
  body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1000px;
    height: 700px;
    background: radial-gradient(ellipse at 50% 0%, rgba(45,212,191,0.09) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Hero ── */
  .calc-hero {
    position: relative;
    overflow: hidden;
    padding: 80px 0 60px;
    min-height: 520px;
    display: flex;
    align-items: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    opacity: 0.18;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 60% 30%, rgba(45,212,191,0.12) 0%, transparent 50%),
      linear-gradient(180deg, rgba(10,10,10,0.4) 0%, rgba(10,10,10,0.85) 60%, #0a0a0a 100%);
  }
  .calc-hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .calc-hero-title {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    margin: 0;
    color: #fff;
    letter-spacing: -0.02em;
  }
  .calc-hero-sub {
    font-size: 17px;
    color: #999;
    margin: 0;
    line-height: 1.6;
    max-width: 420px;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    margin-top: 8px;
    flex-wrap: wrap;
  }
  .hero-cta {
    display: inline-block;
    padding: 14px 28px;
    background: var(--accent);
    color: #000;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: filter 0.2s;
  }
  .hero-cta:hover { filter: brightness(1.15); }
  .hero-cta-secondary {
    display: inline-block;
    padding: 14px 28px;
    background: rgba(255,255,255,0.06);
    color: #ccc;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s;
  }
  .hero-cta-secondary:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.2);
    color: #fff;
  }

  .calc-panel {
    background: rgba(18,22,24,0.75);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 24px 80px rgba(0,0,0,0.5);
  }

  /* ── Empty State ── */
  .calc-empty-state {
    text-align: center;
    padding: 28px 16px 20px;
    color: #666;
  }
  .calc-empty-icon {
    font-size: 40px;
    font-weight: 300;
    color: #444;
    margin-bottom: 12px;
  }
  .calc-empty-title {
    font-size: 16px;
    font-weight: 600;
    color: #888;
    margin-bottom: 6px;
  }
  .calc-empty-desc {
    font-size: 13px;
    color: #555;
    line-height: 1.6;
    max-width: 280px;
    margin: 0 auto;
  }

  /* ── Scenario Cards ── */
  .scenario-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .scenario-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 16px;
  }
  .scenario-card.landfill { border-left: 3px solid rgba(244,114,82,0.6); }
  .scenario-card.recycle { border-left: 3px solid rgba(45,212,191,0.6); }
  .scenario-card-title {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
    color: #999;
  }
  .scenario-card.landfill .scenario-card-title { color: #f4907c; }
  .scenario-card.recycle .scenario-card-title { color: #2dd4bf; }

  .calc-row-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    text-align: center;
    margin-bottom: 10px;
  }
  .calc-row-inner.primary-row {
    grid-template-columns: repeat(2, 1fr);
    margin-bottom: 0;
    padding-top: 10px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .calc-item-small .calc-value {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .calc-item-small.primary .calc-value { color: var(--accent); }
  .calc-item-small .calc-value.recycled { color: #2dd4bf; }
  .calc-item-small .calc-label {
    font-size: 10px;
    color: var(--text-secondary);
    margin-top: 2px;
  }

  .calc-row {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
    text-align: center;
  }

  .calc-value {
    font-size: 26px;
    font-weight: 700;
    color: var(--text);
    font-variant-numeric: tabular-nums;
    transition: color 0.3s;
  }

  .calc-item.primary .calc-value {
    color: var(--accent);
  }

  .calc-label {
    font-size: 11px;
    color: var(--text-secondary);
    margin-top: 2px;
  }

  .calc-status {
    text-align: center;
    margin-top: 12px;
    font-size: 13px;
    color: #555;
  }

  /* ── Scenario labels ── */
  .calc-scenario-label {
    font-size: 12px;
    font-weight: 600;
    color: #777;
    margin-top: 14px;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .calc-scenario-label:first-of-type {
    margin-top: 0;
  }

  .calc-value.recycled {
    color: #2dd4bf;
  }

  .calc-item.primary .calc-value.recycled {
    color: #2dd4bf;
  }

  /* CTUe tooltip */
  .ctue-label {
    position: relative;
    cursor: help;
    border-bottom: 1px dotted #555;
  }

  .ctue-tooltip {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 12px;
    color: #ccc;
    white-space: nowrap;
    font-weight: 400;
    z-index: 10;
    pointer-events: none;
  }

  .ctue-label:hover .ctue-tooltip {
    display: block;
  }

  /* ── Selected items list ── */
  .calc-selected-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 12px;
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }

  .calc-selected-count {
    font-size: 12px;
    font-weight: 400;
    color: var(--text-secondary);
  }

  .calc-selected-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 0;
  }

  .calc-empty-hint {
    text-align: center;
    color: #444;
    font-size: 13px;
    padding: 16px 0;
  }

  .calc-sel-item {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #111;
    border: 1px solid #222;
    border-radius: 8px;
    padding: 8px 12px;
  }

  .calc-sel-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    flex: 1;
    min-width: 0;
  }

  .calc-sel-qty {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
  }

  .calc-sel-qty button {
    width: 34px;
    height: 34px;
    border: 1px solid #444;
    background: #1a1a1a;
    color: #ccc;
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
  }

  .calc-sel-qty button:first-child {
    border-radius: 8px 0 0 8px;
  }

  .calc-sel-qty button:last-child {
    border-radius: 0 8px 8px 0;
  }

  .calc-sel-qty button:hover {
    background: #2a2a2a;
    border-color: #666;
  }

  .calc-sel-qty-val {
    width: 42px;
    height: 34px;
    border-top: 1px solid #444;
    border-bottom: 1px solid #444;
    border-left: none;
    border-right: none;
    background: #0d0d0d;
    color: var(--text);
    font-size: 16px;
    font-weight: 600;
    text-align: center;
