  }

  /* ── Full-screen Modal ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.84);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .modal-overlay[hidden] {
    display: none;
  }

  .modal-panel {
    background: #080808;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px;
    max-width: 780px;
    width: 100%;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 32px 96px rgba(0,0,0,0.7);
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 32px 20px;
    flex-shrink: 0;
  }

  .modal-title {
    font-size: 18px;
    font-weight: 700;
