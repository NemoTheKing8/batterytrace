  .ps-pill.carbon { color: #d4a574; }
  .ps-pill.water  { color: #74a3d4; }
  .ps-pill.metal  { color: #c0a070; }

  /* ── Learn More button ── */
  .ps-learn-btn {
    width: 100%;
    padding: 10px 14px;
