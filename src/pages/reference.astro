  'dgvjbes89k9xylvqjb.jpg',
];
---

<BaseLayout title="About Us — Teardown Gallery" description="Power bank teardown photography — see what's inside your power bank.">
  <meta slot="head" name="robots" content="index, follow" />

  <div class="gallery-page">
    <div class="gallery-header">
      <h1 class="gallery-title">About Us</h1>
      <p class="gallery-subtitle">Every product on batterytrace is disassembled and analyzed. Here's what that looks like.</p>
    </div>

    <div class="carousel" id="carousel" aria-label="Teardown photo gallery" role="region">
      <!-- Main viewport -->
      <div class="carousel-viewport">
        <div class="carousel-track" id="carousel-track">
          {images.map((img, i) => (
            <div class="carousel-slide" data-index={i}>
              <img
                src={`/images/teardown/${img}`}
                alt={`Teardown photo ${i + 1}`}
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </div>
          ))}
        </div>

        <!-- Prev / Next -->
        <button class="carousel-arrow carousel-prev" id="carousel-prev" aria-label="Previous photo">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12 4L6 10L12 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="carousel-arrow carousel-next" id="carousel-next" aria-label="Next photo">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M8 4L14 10L8 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>

      <!-- Controls bar -->
      <div class="carousel-controls">
        <div class="carousel-dots" id="carousel-dots">
          {images.map((_, i) => (
            <button
              class="carousel-dot"
              data-index={i}
              aria-label={`Photo ${i + 1}`}
            ></button>
          ))}
        </div>
        <span class="carousel-counter" id="carousel-counter">1 / {images.length}</span>
      </div>
    </div>

    <!-- Compact References -->
    <div class="ref-compact">
      <h2>References</h2>

      <div class="ref-group">
        <ol>
          <li>Peters, J. F. et al. (2017). The environmental impact of Li-Ion batteries. <em>Renewable and Sustainable Energy Reviews</em>, 67, 491–506.</li>
          <li>GREET Model 2024. Argonne National Laboratory, U.S. Department of Energy.</li>
          <li>Wernet, G. et al. (2016). The ecoinvent database: overview and methodology. <em>Int J Life Cycle Assess</em>, 21(9), 1218–1230.</li>
        </ol>
      </div>

      <div class="ref-group">
        <ol start="4">
          <li>Flexer, V. et al. (2018). Lithium recovery from brines. <em>Science of the Total Environment</em>, 639, 1188–1204.</li>
          <li>Stamp, A. et al. (2012). Environmental impacts of lithium carbonate production. <em>J Cleaner Production</em>, 23(1), 104–112.</li>
        </ol>
      </div>

      <div class="ref-group">
        <ol start="6">
          <li>Majeau-Bettez, G. et al. (2011). Life cycle assessment of lithium-ion batteries. <em>Environ Sci Technol</em>, 45(10), 4548–4554.</li>
          <li>Dunn, J. B. et al. (2015). Li-ion batteries in electric vehicle life-cycle. <em>Energy Environ Sci</em>, 8, 158–168.</li>
          <li>US EPA (2024). Regional Screening Levels (RSLs) – Generic Tables.</li>
          <li>Rosenbaum, R. K. et al. (2008). USEtox — the UNEP-SETAC toxicity model. <em>Int J Life Cycle Assess</em>, 13, 532–546.</li>
        </ol>
      </div>

      <div class="ref-group">
        <ol start="10">
          <li>Harper, G. et al. (2019). Recycling lithium-ion batteries from electric vehicles. <em>Nature</em>, 575, 75–86.</li>
          <li>Melin, H. E. (2019). State-of-the-art in reuse and recycling of lithium-ion batteries. Circular Energy Storage.</li>
          <li>Chen, M. et al. (2019). Recycling end-of-life electric vehicle lithium-ion batteries. <em>Joule</em>, 3(11), 2622–2646.</li>
        </ol>
      </div>

      <div class="ref-group">
        <ol start="13">
          <li>Product BOM data from teardown reports by chongdiantou.com.</li>
        </ol>
      </div>

      <p class="ref-disclaimer">All figures are literature averages, not brand-specific measurements. These numbers provide order-of-magnitude context, not precise declarations.</p>

      <a href="/" class="gallery-back">← Back to calculator</a>
    </div>
  </div>
</BaseLayout>

<style>
  .gallery-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px clamp(24px, 4vw, 80px) 80px;
  }

  .gallery-header {
    margin-bottom: 40px;
  }
  .gallery-title {
    font-size: 28px;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 8px;
  }
  .gallery-subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    margin: 0;
    max-width: 520px;
    line-height: 1.6;
  }

  /* ═══ Carousel ═══ */
  .carousel {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    background: oklch(9% 0.007 165);
    border: 1px solid rgba(255,255,255,0.07);
  }

  .carousel-viewport {
    position: relative;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .carousel-slide {
    flex: 0 0 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 16 / 10;
    background: oklch(9% 0.007 165);
  }

  .carousel-slide img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 16px;
    user-select: none;
    -webkit-user-drag: none;
  }

  /* Arrows */
  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.1);
    background: oklch(9% 0.007 165 / 0.9);
    color: rgba(255,255,255,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    z-index: 2;
    opacity: 0;
  }
  .carousel:hover .carousel-arrow,
  .carousel:focus-within .carousel-arrow { opacity: 1; }

  .carousel-arrow:hover {
    background: oklch(9% 0.007 165 / 0.97);
    color: #fff;
    border-color: rgba(255,255,255,0.25);
  }
  .carousel-prev { left: 12px; }
  .carousel-next { right: 12px; }

  /* Controls */
  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 16px 24px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .carousel-dots {
    display: flex;
    gap: 6px;
  }
  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,0.15);
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }
  .carousel-dot:hover { background: rgba(255,255,255,0.3); }
  .carousel-dot.active { background: #00c896; }

  .carousel-counter {
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    font-variant-numeric: tabular-nums;
    min-width: 52px;
    text-align: center;
  }

  /* Compact References */
  .ref-compact {
    margin-top: 56px;
    max-width: 720px;
  }
  .ref-compact h2 {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 24px;
  }
  .ref-group {
    margin-bottom: 20px;
  }
  .ref-group ol {
    margin: 0;
    padding-left: 20px;
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    line-height: 1.7;
  }
  .ref-group li { margin-bottom: 2px; }
  .ref-group a {
    color: #00c896;
    text-decoration: none;
  }
  .ref-group a:hover { text-decoration: underline; }
  .ref-disclaimer {
    font-size: 12px;
    color: rgba(255,255,255,0.25);
    margin: 32px 0 20px;
    line-height: 1.6;
  }
  .gallery-back {
    display: inline-block;
    font-size: 14px;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    transition: color 0.15s;
  }
  .gallery-back:hover { color: rgba(255,255,255,0.7); }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .carousel-track { transition: none; }
  }

  /* Responsive */
  @media (max-width: 680px) {
    .gallery-page { padding: 32px 16px 60px; }
    .gallery-title { font-size: 22px; }
    .carousel-slide { aspect-ratio: 4 / 3; }
    .carousel-slide img { padding: 8px; }
    .carousel-arrow { width: 36px; height: 36px; opacity: 1; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('carousel-track')!;
    const dots = document.querySelectorAll('.carousel-dot') as NodeListOf<HTMLButtonElement>;
    const counter = document.getElementById('carousel-counter')!;
    const prevBtn = document.getElementById('carousel-prev')!;
    const nextBtn = document.getElementById('carousel-next')!;
    const total = dots.length;

    let current = 0;
    let autoplayTimer: ReturnType<typeof setInterval> | null = null;

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle('active', i === current));
      counter.textContent = `${current + 1} / ${total}`;
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function startAutoplay() {
      stopAutoplay();
      autoplayTimer = setInterval(next, 4000);
    }
    function stopAutoplay() {
      if (autoplayTimer) { clearInterval(autoplayTimer); autoplayTimer = null; }
    }

    prevBtn.addEventListener('click', () => { prev(); startAutoplay(); });
    nextBtn.addEventListener('click', () => { next(); startAutoplay(); });

    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        goTo(parseInt(dot.dataset.index!));
        startAutoplay();
      });
    });

    // Pause on hover
    const carousel = document.getElementById('carousel')!;
    carousel.addEventListener('mouseenter', stopAutoplay);
    carousel.addEventListener('mouseleave', startAutoplay);

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (!carousel.contains(document.activeElement)) return;
      if (e.key === 'ArrowLeft') { prev(); startAutoplay(); }
      if (e.key === 'ArrowRight') { next(); startAutoplay(); }
    });

    // Touch swipe
    let touchStartX = 0;
    track.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', (e) => {
      const diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        diff > 0 ? next() : prev();
        startAutoplay();
      }
    });

    // Init
    goTo(0);
    startAutoplay();
  });
</script>
