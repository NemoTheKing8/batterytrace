---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}
const { title, description = '充电宝环境代价计算器 — 基于学术文献的估算工具' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | batterytrace</title>
  <meta name="description" content={description} />
  <slot name="head" />
</head>
<body>
  <header class="header">
    <div class="logo"><a href="/">battery<span>trace</span></a></div>
    <nav class="nav-links">
      <a href="/">首页</a>
      <a href="#methodology">关于数据</a>
      <a href="#faq">FAQ</a>
    </nav>
  </header>
  <slot />
  <footer class="site-footer">
    <p>数据基于已发表学术文献的估算值，非品牌实测。见每个指标的方法论说明。</p>
  </footer>
</body>
</html>
