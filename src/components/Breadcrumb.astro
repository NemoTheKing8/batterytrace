---
export interface Props {
  items: Array<{ label: string; href?: string }>;
}
const { items } = Astro.props;
---
<div class="breadcrumb">
  {items.map((item, i) => (
    <>
      {i > 0 && <span class="sep">/</span>}
      {item.href ? <a href={item.href}>{item.label}</a> : <span>{item.label}</span>}
    </>
  ))}
</div>
