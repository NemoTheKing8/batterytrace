---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="环境数据建模 — Admin">
  <meta slot="head" name="robots" content="noindex, nofollow" />

  <div class="page-container">
    <h1 class="page-title">环境数据建模工具</h1>
    <p class="page-subtitle">输入产品规格参数，基于文献公式自动计算环境指标估算值。</p>

    <div class="model-layout">
      <!-- Input Panel -->
      <div class="model-panel">
        <h2 class="model-section-title">输入参数</h2>

        <div class="model-field">
          <label class="model-label">产品名称</label>
          <input type="text" id="in-name" class="model-input" value="酷态科 6号超级电能块" />
        </div>

        <div class="model-row">
          <div class="model-field">
            <label class="model-label">标称容量 (mAh)</label>
            <input type="number" id="in-capacity" class="model-input" value="6000" min="1000" max="100000" step="100" />
          </div>
          <div class="model-field">
            <label class="model-label">额定功率 (W)</label>
            <input type="number" id="in-power" class="model-input" value="55" min="5" max="300" />
          </div>
        </div>

        <div class="model-row">
          <div class="model-field">
            <label class="model-label">重量 (g)</label>
            <input type="number" id="in-weight" class="model-input" value="151" min="10" max="2000" />
          </div>
          <div class="model-field">
            <label class="model-label">价格 (¥)</label>
            <input type="number" id="in-price" class="model-input" value="129" min="1" max="9999" />
          </div>
        </div>

        <div class="model-row">
          <div class="model-field">
            <label class="model-label">电芯类型</label>
            <select id="in-cell-type" class="model-input">
              <option value="18650">18650 圆柱</option>
              <option value="21700">21700 圆柱</option>
              <option value="soft">软包聚合物</option>
            </select>
          </div>
          <div class="model-field">
            <label class="model-label">电芯数量 (节)</label>
            <input type="number" id="in-cell-count" class="model-input" value="2" min="1" max="30" />
          </div>
        </div>

        <div class="model-row">
          <div class="model-field">
            <label class="model-label">正极化学</label>
            <select id="in-chemistry" class="model-input">
              <option value="NCM" selected>NCM (镍钴锰酸锂)</option>
              <option value="LFP">LFP (磷酸铁锂)</option>
              <option value="LCO">LCO (钴酸锂)</option>
            </select>
          </div>
          <div class="model-field">
            <label class="model-label">回收率 (0-1)</label>
            <input type="number" id="in-recovery" class="model-input" value="0.95" min="0" max="1" step="0.01" />
          </div>
        </div>

        <button class="model-calc-btn" id="btn-calc">🔄 重新计算</button>
      </div>

      <!-- Output Panel -->
      <div class="model-panel">
        <h2 class="model-section-title">计算结果</h2>

        <table class="model-table">
          <thead>
            <tr><th>指标</th><th>场景 2 (乱丢)</th><th>场景 1 (回收)</th><th>行业平均</th></tr>
          </thead>
          <tbody>
            <tr><td>碳足迹 (kg CO₂eq)</td><td id="out-carbon-landfill">—</td><td id="out-carbon-recycle">—</td><td id="out-carbon-avg">—</td></tr>
            <tr><td>水足迹 (L)</td><td id="out-water-landfill">—</td><td id="out-water-recycle">—</td><td id="out-water-avg">—</td></tr>
            <tr><td>钴 Co (g)</td><td id="out-co-landfill">—</td><td id="out-co-recycle">—</td><td>—</td></tr>
            <tr><td>锂 Li (g)</td><td id="out-li-landfill">—</td><td id="out-li-recycle">—</td><td>—</td></tr>
            <tr><td>镍 Ni (g)</td><td id="out-ni-landfill">—</td><td id="out-ni-recycle">—</td><td>—</td></tr>
            <tr><td>锰 Mn (g)</td><td id="out-mn-landfill">—</td><td id="out-mn-recycle">—</td><td>—</td></tr>
            <tr><td>可回收率 (%)</td><td id="out-recycle-landfill">—</td><td id="out-recycle-recycle">—</td><td id="out-recycle-avg">—</td></tr>
            <tr><td>土壤稀释需求 (吨)</td><td id="out-soil-landfill">—</td><td id="out-soil-recycle">—</td><td>—</td></tr>
          </tbody>
        </table>

        <div style="margin-top: 16px; font-size: 12px; color: #666;">
          所有公式基于已发表文献，具体引用见下方。
        </div>

        <button class="model-export-btn" id="btn-export" style="margin-top: 16px;">📋 导出为 JSON (metrics.json 格式)</button>
        <div id="export-result" style="margin-top: 8px; font-size: 12px; color: #2dd4bf; display: none;"></div>
      </div>
    </div>

    <!-- Formulas Reference -->
    <div class="model-formulas">
      <h2 class="model-section-title">计算公式</h2>
      <div class="formula-grid">
        <div class="formula-card">
          <div class="formula-name">电池能量</div>
          <code>E = capacity_mah × 3.7V ÷ 1,000,000 (kWh)</code>
        </div>
        <div class="formula-card">
          <div class="formula-name">碳足迹</div>
          <code>CO₂ = E × 90 + 1.8 + 0.5 (kg)</code>
          <div class="formula-note">Peters et al. (2017) + Ecoinvent 3.10 + GREET 2024</div>
        </div>
        <div class="formula-card">
          <div class="formula-name">水足迹</div>
          <code>H₂O = E × 14,500 (L)</code>
          <div class="formula-note">Flexer et al. (2018) + Stamp et al. (2012)</div>
        </div>
        <div class="formula-card">
          <div class="formula-name">金属含量 (NCM)</div>
          <code>Co ≈ 1.0g/节, Ni ≈ 0.4g/节, Li ≈ 0.25g/节, Mn ≈ 0.15g/节</code>
          <div class="formula-note">Majeau-Bettez et al. (2011), 正极化学计量比</div>
        </div>
        <div class="formula-card">
          <div class="formula-name">土壤稀释</div>
          <code>Soil = Σ(金属g ÷ RSL mg/kg) ÷ 1000 (吨)</code>
          <div class="formula-note">US EPA Regional Screening Levels</div>
        </div>
        <div class="formula-card">
          <div class="formula-name">场景 1 (回收)</div>
          <code>金属_回收 = 金属_原始 × (1 − recovery_rate)</code>
          <div class="formula-note">默认回收率 95% (Harper et al. 2019, Nature)</div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .model-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin: 24px 0;
  }

  .model-panel {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
  }

  .model-section-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 16px;
  }

  .model-field {
    margin-bottom: 14px;
    flex: 1;
  }

  .model-row {
    display: flex;
    gap: 12px;
  }

  .model-label {
    display: block;
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: 4px;
    font-weight: 500;
  }

  .model-input {
    width: 100%;
    padding: 8px 12px;
    background: #111;
    border: 1px solid #333;
    border-radius: 6px;
    color: var(--text);
    font-size: 14px;
    font-family: inherit;
    box-sizing: border-box;
    transition: border-color 0.15s;
  }

  .model-input:focus {
    border-color: var(--accent);
    outline: none;
  }

  select.model-input {
    cursor: pointer;
  }

  .model-calc-btn, .model-export-btn {
    width: 100%;
    padding: 10px;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    font-family: inherit;
  }

  .model-calc-btn {
    background: var(--accent);
    color: #000;
  }

  .model-calc-btn:hover {
    filter: brightness(1.1);
  }

  .model-export-btn {
    background: #1a1a1a;
    color: #ccc;
    border: 1px solid #333;
  }

  .model-export-btn:hover {
    background: #222;
    color: #fff;
  }

  /* Table */
  .model-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }

  .model-table th, .model-table td {
    padding: 8px 10px;
    text-align: right;
    border-bottom: 1px solid #1a1a1a;
  }

  .model-table th {
    color: var(--text-secondary);
    font-weight: 500;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .model-table td {
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }

  .model-table td:first-child, .model-table th:first-child {
    text-align: left;
  }

  /* Formulas */
  .model-formulas {
    margin-top: 24px;
  }

  .formula-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .formula-card {
    background: #0d0d0d;
    border: 1px solid #1a1a1a;
    border-radius: 8px;
    padding: 14px;
  }

  .formula-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .formula-card code {
    display: block;
    font-size: 13px;
    color: #ccc;
    margin-bottom: 6px;
    background: #000;
    padding: 6px 8px;
    border-radius: 4px;
    word-break: break-all;
  }

  .formula-note {
    font-size: 11px;
    color: #555;
  }

  @media (max-width: 680px) {
    .model-layout {
      grid-template-columns: 1fr;
    }

    .formula-grid {
      grid-template-columns: 1fr;
    }

    .model-row {
      flex-direction: column;
      gap: 0;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const btnCalc = document.getElementById('btn-calc')!;
    const btnExport = document.getElementById('btn-export')!;
    const exportResult = document.getElementById('export-result')!;

    // Chemistry-specific metal content per cell (grams)
    const metalPerCell: Record<string, { co: number; li: number; ni: number; mn: number }> = {
      'NCM': { co: 1.0, li: 0.25, ni: 0.4, mn: 0.15 },
      'LFP': { co: 0, li: 0.30, ni: 0, mn: 0 },
      'LCO': { co: 2.5, li: 0.30, ni: 0, mn: 0 },
    };

    const epaRSL: Record<string, number> = {
      co: 23,   // mg/kg → US EPA RSL residential soil
      ni: 1600,
    };

    function getVal(id: string): number {
      return parseFloat((document.getElementById(id) as HTMLInputElement).value) || 0;
    }

    function setVal(id: string, val: string) {
      document.getElementById(id)!.textContent = val;
    }

    function calc() {
      const capacity = getVal('in-capacity');
      const cellCount = getVal('in-cell-count');
      const chemistry = (document.getElementById('in-chemistry') as HTMLSelectElement).value;
      const recovery = getVal('in-recovery');

      const metals = metalPerCell[chemistry] || metalPerCell['NCM'];

      // Battery energy
      const energyKwh = capacity * 3.7 / 1_000_000;

      // Carbon = production + disposal
      const carbonProd = +(energyKwh * 90 + 1.8 + 0.5).toFixed(1);
      const carbonLandfill = +(carbonProd + 0.3).toFixed(1);
      const carbonRecycle = +(carbonProd + 0.15).toFixed(1);
      const carbonAvg = +(energyKwh * 115 + 1.8).toFixed(1);

      // Water = production + disposal
      const waterProd = Math.round(energyKwh * 14500);
      const waterLandfill = waterProd + 20;
      const waterRecycle = waterProd + 10;
      const waterAvg = Math.round(energyKwh * 18500);

      // Metals
      const coRaw = +(metals.co * cellCount).toFixed(1);
      const liRaw = +(metals.li * cellCount).toFixed(1);
      const niRaw = +(metals.ni * cellCount).toFixed(1);
      const mnRaw = +(metals.mn * cellCount).toFixed(1);

      const coRecycled = +(coRaw * (1 - recovery)).toFixed(2);
      const liRecycled = +(liRaw * (1 - recovery)).toFixed(2);
      const niRecycled = +(niRaw * (1 - recovery)).toFixed(2);
      const mnRecycled = +(mnRaw * (1 - recovery)).toFixed(2);

      // Soil dilution (landfill scenario)
      const soilLandfill = +((coRaw / epaRSL.co + niRaw / epaRSL.ni) * 1000 / 1000).toFixed(1);
      const soilRecycle = +((coRecycled / epaRSL.co + niRecycled / epaRSL.ni) * 1000 / 1000).toFixed(2);

      // Recyclability
      const recyclablePct = 38;
      const recyclableAvg = 32;

      // Display
      setVal('out-carbon-landfill', carbonLandfill.toString());
      setVal('out-carbon-recycle', carbonRecycle.toString());
      setVal('out-carbon-avg', carbonAvg.toString());

      setVal('out-water-landfill', waterLandfill.toLocaleString());
      setVal('out-water-recycle', waterRecycle.toLocaleString());
      setVal('out-water-avg', waterAvg.toLocaleString());

      setVal('out-co-landfill', coRaw.toString());
      setVal('out-co-recycle', coRecycled.toString());
      setVal('out-li-landfill', liRaw.toString());
      setVal('out-li-recycle', liRecycled.toString());
      setVal('out-ni-landfill', niRaw.toString());
      setVal('out-ni-recycle', niRecycled.toString());
      setVal('out-mn-landfill', mnRaw.toString());
      setVal('out-mn-recycle', mnRecycled.toString());

      setVal('out-recycle-landfill', recyclablePct + '%');
      setVal('out-recycle-recycle', recyclablePct + '%');
      setVal('out-recycle-avg', recyclableAvg + '%');

      setVal('out-soil-landfill', soilLandfill + ' 吨');
      setVal('out-soil-recycle', soilRecycle + ' 吨');
    }

    btnCalc.addEventListener('click', calc);

    btnExport.addEventListener('click', () => {
      const capacity = getVal('in-capacity');
      const cellCount = getVal('in-cell-count');
      const chemistry = (document.getElementById('in-chemistry') as HTMLSelectElement).value;
      const recovery = getVal('in-recovery');
      const metals = metalPerCell[chemistry] || metalPerCell['NCM'];
      const energyKwh = capacity * 3.7 / 1_000_000;
      const carbon = +(energyKwh * 90 + 1.8 + 0.5).toFixed(1);
      const water = Math.round(energyKwh * 14500);

      const json = {
        product_id: "FIXME-product-id",
        carbon_kg_co2eq: carbon,
        carbon_industry_low: +(carbon * 0.6).toFixed(1),
        carbon_industry_avg: +(carbon * 1.4).toFixed(1),
        carbon_industry_high: +(carbon * 2.5).toFixed(1),
        water_liters: water,
        water_industry_low: Math.round(water * 0.6),
        water_industry_avg: Math.round(water * 1.5),
        water_industry_high: Math.round(water * 3.0),
        cobalt_g: +(metals.co * cellCount).toFixed(1),
        nickel_g: +(metals.ni * cellCount).toFixed(1),
        lithium_g: +(metals.li * cellCount).toFixed(1),
        manganese_g: +(metals.mn * cellCount).toFixed(1),
        toxic_soil_dilution_tonnes: +(+(metals.co * cellCount).toFixed(1) / 23 / 1000).toFixed(1),
        cobalt_soil_dilution_tonnes: +(+(metals.co * cellCount).toFixed(1) / 23 / 1000).toFixed(1),
        nickel_soil_dilution_tonnes: +(+(metals.ni * cellCount).toFixed(1) / 1600 / 1000).toFixed(2),
        plastic_degradation_years: 400,
        aluminum_degradation_years: 150,
        pcb_degradable: false,
        cell_degradation_years: 100,
        recyclable_pct: 38,
        recyclable_industry_avg: 32,
        recovery_rate: recovery,
        carbon_disposal_landfill: 0.3,
        carbon_disposal_recycle: 0.15,
        water_disposal_landfill: 20,
        water_disposal_recycle: 10,
        production_energy_mj: +(energyKwh * 90 * 3.6 * 0.5).toFixed(1),
        energy_per_full_cycle_mj: +(energyKwh * 3.6).toFixed(2),
        break_even_cycles: Math.round((energyKwh * 90 * 3.6 * 0.5) / (energyKwh * 3.6)),
        equivalences: {
          carbon: [],
          water: [],
          toxic: [],
          degrade: [],
          recycle: [],
          energy: []
        }
      };

      navigator.clipboard.writeText(JSON.stringify(json, null, 2)).then(() => {
        exportResult.style.display = 'block';
        exportResult.textContent = '✅ 已复制到剪贴板！粘贴到 metrics.json 后修改 product_id 即可。';
      }).catch(() => {
        exportResult.style.display = 'block';
        exportResult.textContent = '⚠ 复制失败，请手动选择文本框内容复制。';
      });
    });

    // Calculate on load
    calc();
  });
</script>
