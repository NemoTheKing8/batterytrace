<BaseLayout title="Materials — Bill of Materials" description="Product teardown bill of materials from chongdiantou.com">
  <div class="page-container">
    <h1 class="page-title">Materials</h1>
    <p class="page-subtitle" style="margin-bottom: 32px;">物料清单来自充电头网公开拆解报告。</p>

    {products.filter(p => productBom[p.id]).map(p => (
      <section style="margin-bottom: 40px;">
        <h2 style="font-size:18px;font-weight:700;margin-bottom:12px;color:var(--text);">{p.name}</h2>
        <div style="overflow-x:auto;border:1px solid var(--border);border-radius:10px;">
          <table style="width:100%;border-collapse:collapse;font-size:12px;">
            <thead>
              <tr style="background:var(--card);color:var(--text-secondary);font-size:11px;text-transform:uppercase;letter-spacing:0.04em;">
                <th style="padding:10px 12px;text-align:left;border-bottom:1px solid var(--border);">类型</th>
                <th style="padding:10px 12px;text-align:left;border-bottom:1px solid var(--border);">功能</th>
                <th style="padding:10px 12px;text-align:left;border-bottom:1px solid var(--border);">品牌</th>
                <th style="padding:10px 12px;text-align:left;border-bottom:1px solid var(--border);">规格</th>
                <th style="padding:10px 12px;text-align:left;border-bottom:1px solid var(--border);">封装</th>
                <th style="padding:10px 12px;text-align:center;border-bottom:1px solid var(--border);">数量</th>
              </tr>
            </thead>
            <tbody>
              {(productBom[p.id] || []).map(row => (
                <tr style="border-bottom:1px solid rgba(0,0,0,0.04);">
                  <td style="padding:9px 12px;color:#60a5fa;font-weight:500;">{row.cat}</td>
                  <td style="padding:9px 12px;color:var(--text);">{row.fn}</td>
                  <td style="padding:9px 12px;color:var(--text-secondary);">{row.brand || '—'}</td>
                  <td style="padding:9px 12px;color:var(--text-secondary);">{row.spec}</td>
                  <td style="padding:9px 12px;color:var(--text-secondary);">{row.pkg}</td>
                  <td style="padding:9px 12px;text-align:center;font-weight:600;color:var(--text);">{row.qty}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
