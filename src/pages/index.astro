  }

  /* ── Card info below image ── */
  .ps-card-info {
    padding: 12px 14px;
    flex: 1;
  }

  .ps-card-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 4px;
  }

  .ps-card-specs {
    font-size: 11px;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }

  .ps-card-pills {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .ps-pill {
    font-size: 10px;
    padding: 2px 7px;
    border-radius: 10px;
