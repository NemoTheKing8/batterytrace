    transition: all 0.15s;
  }

  .calc-clear-btn:hover {
    border-color: var(--accent-danger);
    color: var(--accent-danger);
  }

  /* ── Brand Section ── */
  .brand-section {
    margin-top: 32px;
  }

  .brand-section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid #222;
  }

  .brand-section-icon {
    font-size: 28px;
  }

  .brand-section-title {
    font-size: 22px;
    font-weight: 700;
    margin: 0;
    color: var(--text);
  }

  .brand-section-en {
    font-size: 13px;
    font-weight: 400;
    color: var(--text-secondary);
  }

  /* ── Product Select Grid ── */
  .product-select-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 14px;
  }

  .ps-card {
    background: var(--card);
    border: 2px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.25s, box-shadow 0.25s;
    display: flex;
    flex-direction: column;
    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  }
  .ps-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 36px rgba(0,0,0,0.55);
  }
  .ps-card:nth-child(6n+1) { z-index: 5; }
  .ps-card:nth-child(6n+2) { z-index: 4; }
  .ps-card:nth-child(6n+3) { z-index: 3; }
