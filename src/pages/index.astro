---

<BaseLayout title="充电宝环境影响计算器" description="选择酷态科充电宝产品，估算从制造到废弃的金属流失、碳足迹与生态毒性。">

  <!-- ═══ Hero ═══ -->
  <div class="calc-hero" id="hero">
    <div class="hero-bg">
      <img src={heroBg.src} alt="" />
    </div>
    <div class="calc-hero-inner">
      <div class="hero-text">
        <h1 class="calc-hero-title">充电宝环境影响计算器</h1>
        <p class="calc-hero-sub">选择具体型号，估算电池材料流失、碳排放与生态毒性影响，对比规范回收前后的差异。</p>
        <div class="hero-actions">
          <a href="#calculator" class="hero-cta">选择产品开始计算</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══ Calculator Section ═══ -->
  <section class="calculator-section" id="calculator">
    <div class="calculator-section-inner">
    <div class="calc-panel" id="calc-panel">
      <div class="calc-selected-header">
        <span>已选商品</span>
        <span class="calc-selected-count" id="calc-status">尚未选择</span>
      </div>
      <div class="calc-selected-list" id="selected-items">
        <div class="calc-empty-state" id="calc-empty">
          <div class="calc-empty-title">尚未选择产品</div>
          <div class="calc-empty-desc">在下方产品网格中点击任意产品即可开始。</div>
        </div>
      </div>
      <div id="calc-results" style="display:none;">
        <div class="calc-divider" style="margin-top:0;"></div>
        <div class="scenario-cards">
          <div class="scenario-card landfill">
            <div class="scenario-card-title">未规范回收</div>
            <div class="calc-row-inner primary-row">
              <div class="calc-item-small primary">
                <div class="calc-value" id="sum-carbon">0</div>
                <div class="calc-label">碳足迹 (kg CO₂eq)<br><span class="carbon-analogy" id="carbon-analogy-lf">≈ 燃油车行驶约 0 km</span></div>
              </div>
              <div class="calc-item-small primary">
                <div class="calc-value" id="sum-ctue">0</div>
                <div class="calc-label ctue-label">
                  生态毒性 CTUe
                  <span class="ctue-tooltip">假设单个池塘大小为 1000m³，同时该结果不代表实际死亡比例。</span>
                  <br><span class="carbon-analogy" id="ctue-analogy-lf">≈ 1000m³ 小池塘中约 0% 水生物种承压 3 小时</span>
                </div>
              </div>
            </div>
            <div class="metal-detail" id="metal-detail-landfill" style="display:none;">
              <div class="calc-row-inner">
                <div class="calc-item-small"><div class="calc-value" id="sum-co-landfill">0</div><div class="calc-label">钴 Co (g)</div></div>
                <div class="calc-item-small"><div class="calc-value" id="sum-li-landfill">0</div><div class="calc-label">锂 Li (g)</div></div>
                <div class="calc-item-small"><div class="calc-value" id="sum-ni-landfill">0</div><div class="calc-label">镍 Ni (g)</div></div>
                <div class="calc-item-small"><div class="calc-value" id="sum-mn-landfill">0</div><div class="calc-label">锰 Mn (g)</div></div>
              </div>
            </div>
          </div>
          <div class="scenario-card recycle">
            <div class="scenario-card-title">规范回收</div>
            <div class="calc-row-inner primary-row">
              <div class="calc-item-small primary">
                <div class="calc-value" id="sum-carbon-r">0</div>
                <div class="calc-label">碳足迹 (kg CO₂eq)<br><span class="carbon-analogy" id="carbon-analogy-rc">≈ 燃油车行驶约 0 km</span></div>
              </div>
              <div class="calc-item-small primary">
                <div class="calc-value" id="sum-ctue-r">0</div>
                <div class="calc-label">
                  生态毒性 CTUe
                  <br><span class="carbon-analogy" id="ctue-analogy-rc">≈ 1000m³ 小池塘中约 0% 水生物种承压 3 小时</span>
                </div>
              </div>
            </div>
            <div class="metal-detail" id="metal-detail-recycle" style="display:none;">
              <div class="calc-row-inner">
                <div class="calc-item-small"><div class="calc-value recycled" id="sum-co-recycle">0</div><div class="calc-label">钴 Co (g)</div></div>
                <div class="calc-item-small"><div class="calc-value recycled" id="sum-li-recycle">0</div><div class="calc-label">锂 Li (g)</div></div>
                <div class="calc-item-small"><div class="calc-value recycled" id="sum-ni-recycle">0</div><div class="calc-label">镍 Ni (g)</div></div>
                <div class="calc-item-small"><div class="calc-value recycled" id="sum-mn-recycle">0</div><div class="calc-label">锰 Mn (g)</div></div>
              </div>
            </div>
          </div>
        </div>
        <button class="metal-toggle" id="metal-toggle" style="display:none;">查看材料明细</button>
        <div class="ctue-footnote" id="ctue-footnote" style="display:none;"></div>
        <div class="calc-total-bar" id="calc-total-bar" style="display:none;">
          <button class="calc-clear-btn" id="calc-clear">清空</button>
        </div>
      </div>
    </div>
    </div>
  </section>

  <div class="page-container" style="padding-top: 0;">

    <!-- ═══ Brand Section (一级窗口) ═══ -->
    <section class="brand-section">
      <div class="brand-section-header">
        <h2 class="brand-section-title">{brand.name} <span class="brand-section-en">{brand.name_en}</span></h2>
      </div>

      <!-- Product selection cards -->
      <div class="product-select-grid" id="product-list" id="power-banks">
        {catalog.map((item, i) => {
          const metalTotal = (item.metrics.cobalt_g + item.metrics.nickel_g + item.metrics.lithium_g + item.metrics.manganese_g).toFixed(1);
          return (
            <article class="product-card" data-id={item.product.id}
              data-co={item.metrics.cobalt_g}
              data-li={item.metrics.lithium_g}
              data-ni={item.metrics.nickel_g}
              data-mn={item.metrics.manganese_g}
              data-carbon={item.metrics.carbon_kg_co2eq}
              data-water={item.metrics.water_liters}
              data-recovery={item.metrics.recovery_rate ?? 0.95}
              data-carbon-lf={item.metrics.carbon_disposal_landfill ?? 0.3}
              data-carbon-rc={item.metrics.carbon_disposal_recycle ?? 0.15}
              data-water-lf={item.metrics.water_disposal_landfill ?? 20}
              data-water-rc={item.metrics.water_disposal_recycle ?? 10}
              data-ctue-lf={item.metrics.ctue_landfill ?? 6.2}
              data-ctue-rc={item.metrics.ctue_recycle ?? 0.31}
              data-name={item.product.name}
              data-specs={`${item.product.capacity_mah.toLocaleString()}mAh · ${item.product.power_w}W · ${item.product.weight_g}g`}
              data-bom={JSON.stringify(productBom[item.product.id] || [])}>
              <div class="product-image-wrap">
                <img src={item.product.image} alt={item.product.name} class="product-img" loading="lazy" />
                <span class="selected-mark">✓</span>
              </div>
              <div class="product-card-info">
                <h3 class="product-card-name">{item.product.name}</h3>
                <p class="product-card-specs">{item.product.capacity_mah.toLocaleString()}mAh · {item.product.power_w}W · {item.product.weight_g}g · ¥{item.product.price_cny}</p>
                <span class="carbon-note">{item.metrics.carbon_kg_co2eq} kg CO₂eq</span>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <!-- Disclaimer -->
    <div class="disclaimer-bar" style="margin-top: 32px;">
      <div class="disclaimer">
        <strong>估算数据，非品牌实测。</strong> 以上数字基于已发表学术文献及充电头网拆解报告中对电芯型号、材料的分析做出的最佳近似。酷态科未提供或认可这些数据。组件污染来源信息基于拆解报告的物料清单推断。
      </div>
    </div>

    <div class="methodology">
      <a href="/reference" class="ref-link">Data sources, methods & references →</a>
    </div>

    <!-- Full-screen modal for 了解更多 -->
    <div class="modal-overlay" id="learn-modal" hidden>
      <div class="modal-panel">
        <div class="modal-header">
          <h3 class="modal-title" id="modal-title">充电宝内部的污染来源</h3>
          <button class="modal-close" id="modal-close">✕</button>
        </div>
        <div class="modal-body" id="modal-body"></div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Global Glow ── */
  body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse at 50% 0%, rgba(45,212,191,0.04) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Hero ── */
  .calc-hero {
    position: relative;
    overflow: hidden;
    padding: 0;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    opacity: 1;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.55) 0%, transparent 45%, transparent 65%, rgba(0,0,0,0.7) 100%);
  }
  .calc-hero-inner {
    position: relative;
    z-index: 1;
    margin: 0 auto;
    padding: 0 clamp(32px, 6vw, 100px);
    width: 100%;
    display: flex;
    align-items: center;
    height: 100%;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 640px;
  }
  .calc-hero-title {
    font-size: clamp(48px, 5vw, 72px);
    font-weight: 300;
    line-height: 1.05;
    margin: 0;
    color: #fff;
    letter-spacing: -0.02em;
  }
  .calc-hero-sub {
    font-size: 18px;
    color: rgba(255,255,255,0.65);
    margin: 0;
    line-height: 1.8;
    max-width: 480px;
    font-weight: 300;
    letter-spacing: 0.01em;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    margin-top: 8px;
    flex-wrap: wrap;
  }
  .hero-cta {
    display: inline-block;
    padding: 16px 36px;
    background: rgba(255,255,255,0.12);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 6px;
    font-size: 15px;
    font-weight: 400;
    letter-spacing: 0.04em;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition: background 0.3s, border-color 0.3s;
  }
  .hero-cta:hover { background: rgba(255,255,255,0.2); border-color: rgba(255,255,255,0.45); }

  /* ── Calculator Section ── */
  .calculator-section {
    position: relative;
    z-index: 2;
    background: linear-gradient(180deg, #050607 0%, #0d1117 45%, #f7f8fa 100%);
    padding: 80px clamp(24px, 4vw, 80px) 80px;
    margin-top: -1px;
  }
  .calculator-section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .calc-panel {
    background: rgba(10,12,16,0.9);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 28px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    color: rgba(255,255,255,0.9);
    max-height: min(78vh, 760px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── Empty State ── */
  .calc-empty-state {
    text-align: center;
    padding: 28px 16px 20px;
    color: #666;
  }
  .calc-empty-icon {
    font-size: 40px;
    font-weight: 300;
    color: #444;
    margin-bottom: 12px;
  }
  .calc-empty-title {
    font-size: 16px;
    font-weight: 600;
    color: #888;
    margin-bottom: 6px;
  }
  .calc-empty-desc {
    font-size: 13px;
    color: #555;
    line-height: 1.6;
    max-width: 280px;
    margin: 0 auto;
  }

  /* ── Scenario Cards ── */
  .scenario-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .scenario-card {
    background: rgba(0,0,0,0.02);
    border: 1px solid rgba(0,0,0,0.07);
    border-radius: 12px;
    padding: 16px;
  }
  .scenario-card.landfill { border-left: 3px solid rgba(244,114,82,0.6); }
  .scenario-card.recycle { border-left: 3px solid rgba(45,212,191,0.6); }
  .scenario-card-title {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
    color: #999;
  }
  .scenario-card.landfill .scenario-card-title { color: #f4907c; }
  .scenario-card.landfill .calc-value { color: #f4907c !important; }
  .scenario-card.recycle .scenario-card-title { color: #2dd4bf; }

  .calc-row-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    text-align: center;
    margin-bottom: 10px;
  }
  .calc-row-inner.primary-row {
    grid-template-columns: repeat(2, 1fr);
    margin-bottom: 0;
    padding-top: 10px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .calc-item-small .calc-value {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    font-variant-numeric: tabular-nums;
  }
  .calc-item-small.primary .calc-value { color: var(--accent); }
  .calc-item-small .calc-value.recycled { color: #2dd4bf; }
  .calc-item-small .calc-label {
    font-size: 10px;
    color: var(--text-secondary);
    margin-top: 2px;
  }

  .calc-row {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
    text-align: center;
  }

  .calc-value {
    font-size: 26px;
    font-weight: 700;
    color: var(--text);
    font-variant-numeric: tabular-nums;
    transition: color 0.3s;
  }

  .calc-item.primary .calc-value {
    color: var(--accent);
  }

  .calc-label {
    font-size: 11px;
    color: var(--text-secondary);
    margin-top: 2px;
  }

  .calc-status {
    text-align: center;
    margin-top: 12px;
    font-size: 13px;
    color: #555;
  }

  /* ── Scenario labels ── */
  .calc-scenario-label {
    font-size: 12px;
    font-weight: 600;
    color: #777;
    margin-top: 14px;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .calc-scenario-label:first-of-type {
    margin-top: 0;
  }

  .calc-value.recycled {
    color: #2dd4bf;
  }

  .calc-item.primary .calc-value.recycled {
    color: #2dd4bf;
  }

  /* CTUe tooltip */
  .ctue-label {
    position: relative;
    cursor: help;
    border-bottom: 1px dotted #555;
  }

  .carbon-analogy {
    display: inline-block;
    font-size: 10px;
    color: rgba(255,255,255,0.35);
    font-weight: 400;
    margin-top: 2px;
  }
  .ctue-tooltip {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 12px;
    color: #ccc;
    white-space: nowrap;
    font-weight: 400;
    z-index: 10;
    pointer-events: none;
  }

  .ctue-label:hover .ctue-tooltip {
    display: block;
  }

  /* ── Selected items list ── */
  .calc-selected-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 12px;
    font-size: 15px;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
  }

  .calc-selected-count {
    font-size: 12px;
    font-weight: 400;
    color: var(--text-secondary);
  }

  .calc-selected-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-height: 0;
    max-height: 168px;
    overflow-y: auto;
    padding-right: 4px;
    margin-top: 8px;
  }

  .calc-selected-list::-webkit-scrollbar { width: 4px; }
  .calc-selected-list::-webkit-scrollbar-thumb {
    background: rgba(255,255,255,0.15);
    border-radius: 99px;
  }

  .calc-empty-hint {
    text-align: center;
    color: #444;
    font-size: 13px;
    padding: 16px 0;
  }

  /* selected-item styles are in global.css (must hit dynamic DOM) */

  .calc-divider {
    height: 1px;
    background: #222;
    margin: 16px 0;
  }

  .calc-total-bar {
    display: flex;
    justify-content: center;
    margin-top: 12px;
  }

  .calc-clear-btn {
    display: block;
    margin: 8px auto 0;
    padding: 4px 16px;
    background: none;
    border: 1px solid #333;
    color: #777;
    border-radius: 16px;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.15s;
  }

  .calc-clear-btn:hover {
    border-color: var(--accent-danger);
    color: var(--accent-danger);
  }

  /* ── Brand Section ── */
  .brand-section {
    margin-top: 32px;
  }

  .brand-section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid #222;
  }

  .brand-section-icon {
    font-size: 28px;
  }

  .brand-section-title {
    font-size: 22px;
    font-weight: 700;
    margin: 0;
    color: var(--text);
  }

  .brand-section-en {
    font-size: 13px;
    font-weight: 400;
    color: var(--text-secondary);
  }

  /* ── Product Select Grid (new) ── */
  .product-select-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    width: 100%;
  }

  .product-card {
    background: transparent;
    border: none;
    border-radius: 16px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    width: 100%;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
  }
  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 48px rgba(0,0,0,0.12);
  }
  .product-card.selected {
    box-shadow: 0 0 0 2px #00b98b, 0 8px 32px rgba(0,0,0,0.1);
  }

  .product-image-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #fafafa;
  }
  .product-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 32px;
    transition: transform 0.5s ease;
  }
  .product-card:hover .product-img { transform: scale(1.06); }

  .selected-mark {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.2);
    background: rgba(0,0,0,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    color: transparent;
    transition: all 0.2s;
  }
  .product-card.selected .selected-mark {
    background: #00b98b;
    border-color: #00b98b;
    color: #03110d;
  }

  .product-card-info { padding: 18px 20px; }
  .product-card-name {
    font-size: 16px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .product-card-specs {
    font-size: 14px;
    color: rgba(0,0,0,0.5);
    margin: 0 0 8px;
  }
  .carbon-note {
    font-size: 13px;
    color: #00b98b;
    font-weight: 500;
  }

  /* ── Full-screen Modal ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.84);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .modal-overlay[hidden] {
    display: none;
  }

  .modal-panel {
    background: #080808;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px;
    max-width: 780px;
    width: 100%;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 32px 96px rgba(0,0,0,0.7);
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 32px 20px;
    flex-shrink: 0;
  }

  .modal-title {
    font-size: 18px;
    font-weight: 700;
    color: #FFFFFF;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .modal-close {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    color: #888;
    font-size: 16px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .modal-close:hover {
    background: rgba(255,255,255,0.08);
    color: #fff;
    border-color: rgba(255,255,255,0.2);
  }

  .modal-body {
    padding: 2px 32px 36px;
    overflow-y: auto;
    flex: 1;
  }

  /* ── Info Cards ── */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .info-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 16px;
    transition: border-color 0.2s, background 0.2s;
  }

  .info-card:hover {
    border-color: rgba(255,255,255,0.14);
    background: rgba(255,255,255,0.05);
  }

  .info-card-title {
    font-size: 15px;
    font-weight: 600;
    color: #FFFFFF;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }

  .info-card-detail {
    font-size: 13px;
    color: #B8B8B8;
    line-height: 1.65;
  }

  /* ── BOM Table ── */
  .bom-section {
    margin-top: 32px;
  }

  .bom-title {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 12px;
  }

  .bom-table-wrap {
    overflow-x: auto;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
  }

  .bom-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    white-space: nowrap;
  }

  .bom-table th {
    background: rgba(255,255,255,0.04);
    color: #999;
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 10px 12px;
    text-align: left;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    position: sticky;
    top: 0;
  }

  .bom-table td {
    padding: 9px 12px;
    color: #B8B8B8;
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }

  .bom-table tr:hover td {
    background: rgba(255,255,255,0.02);
  }

  .bom-table td:first-child {
    color: #60a5fa;
    font-weight: 500;
  }

  .bom-table td:last-child {
    color: #fff;
    font-weight: 600;
    text-align: center;
  }

  @media (max-width: 680px) {
    .modal-overlay {
      padding: 12px;
    }

    .modal-panel {
      max-height: 92vh;
      border-radius: 16px;
    }

    .modal-header {
      padding: 20px 20px 16px;
    }

    .modal-body {
      padding: 2px 20px 24px;
    }

    .info-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  }

  /* Pulse animation for totals */
  @keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.08); color: var(--accent); }
    100% { transform: scale(1); }
  }

  .calc-value.pulse {
    animation: pulse 0.35s ease;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .product-select-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 860px) {
    .calc-hero {
      height: 70vh;
      min-height: 500px;
    }
    .calc-hero-title {
      font-size: 36px;
    }
    .hero-text {
      max-width: 100%;
    }
    .scenario-cards {
      grid-template-columns: 1fr;
    }
    .calculator-section {
      padding: 60px 24px 60px;
    }
  }

  @media (max-width: 680px) {
    .product-select-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
    .product-card-name { font-size: 13px; }

    .calc-hero {
      height: 60vh;
      min-height: 420px;
    }

    .calc-hero-title {
      font-size: 28px;
    }

    .calc-hero-sub {
      font-size: 15px;
    }

    .hero-cta {
      padding: 14px 28px;
      font-size: 14px;
    }

    .calculator-section {
      padding: 48px 16px 48px;
    }

    .calc-row-inner {
      grid-template-columns: repeat(2, 1fr);
    }

    .calc-value {
      grid-template-columns: 1fr;
    }

    .product-card-name { font-size: 13px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const productCards = document.querySelectorAll('.product-card') as NodeListOf<HTMLElement>;
    const selectedList = document.getElementById('selected-items')!;
    const calcStatus = document.getElementById('calc-status')!;
    const calcTotalBar = document.getElementById('calc-total-bar')!;
    const clearBtn = document.getElementById('calc-clear')!;
    const metalToggle = document.getElementById('metal-toggle')!;

    // Totals elements — landfill
    const sumCoL = document.getElementById('sum-co-landfill')!;
    const sumLiL = document.getElementById('sum-li-landfill')!;
    const sumNiL = document.getElementById('sum-ni-landfill')!;
    const sumMnL = document.getElementById('sum-mn-landfill')!;
    // Totals elements — recycle
    const sumCoR = document.getElementById('sum-co-recycle')!;
    const sumLiR = document.getElementById('sum-li-recycle')!;
    const sumNiR = document.getElementById('sum-ni-recycle')!;
    const sumMnR = document.getElementById('sum-mn-recycle')!;
    // Carbon & CTUe
    const sumCarbon = document.getElementById('sum-carbon')!;
    const sumCarbonR = document.getElementById('sum-carbon-r')!;
    const sumCtue = document.getElementById('sum-ctue')!;
    const sumCtueR = document.getElementById('sum-ctue-r')!;
    const metalDetailL = document.getElementById('metal-detail-landfill')!;
    const metalDetailR = document.getElementById('metal-detail-recycle')!;

    // State
    const selected = new Map<string, number>();
    let metalsVisible = false;

    // Product metadata from card dataset
    const productMeta = new Map<string, { name: string; spec: string; co: number; li: number; ni: number; mn: number; carbon: number; water: number; recovery: number; carbonLf: number; carbonRc: number; waterLf: number; waterRc: number; ctueLf: number; ctueRc: number; bom: string }>();

    productCards.forEach(card => {
      const el = card as HTMLElement;
      const id = el.dataset.id!;
      productMeta.set(id, {
        name: el.dataset.name || id,
        spec: el.dataset.specs || '',
        co: parseFloat(el.dataset.co || '0'),
        li: parseFloat(el.dataset.li || '0'),
        ni: parseFloat(el.dataset.ni || '0'),
        mn: parseFloat(el.dataset.mn || '0'),
        carbon: parseFloat(el.dataset.carbon || '0'),
        water: parseFloat(el.dataset.water || '0'),
        recovery: parseFloat(el.dataset.recovery || '0.95'),
        carbonLf: parseFloat(el.dataset.carbonLf || '0.3'),
        carbonRc: parseFloat(el.dataset.carbonRc || '0.15'),
        waterLf: parseFloat(el.dataset.waterLf || '20'),
        waterRc: parseFloat(el.dataset.waterRc || '10'),
        ctueLf: parseFloat(el.dataset.ctueLf || '6.2'),
        ctueRc: parseFloat(el.dataset.ctueRc || '0.31'),
        bom: el.dataset.bom || '[]',
      });
    });

    const calcEmpty = document.getElementById('calc-empty')!;
    const calcResults = document.getElementById('calc-results')!;

    function render() {
      if (selected.size === 0) {
        selectedList.innerHTML = '';
        calcStatus.textContent = '尚未选择';
        calcTotalBar.style.display = 'none';
        metalToggle.style.display = 'none';
        calcEmpty.style.display = '';
        calcResults.style.display = 'none';
      } else {
        const totalQty = Array.from(selected.values()).reduce((a,b) => a+b, 0);
        calcStatus.textContent = `已选 ${selected.size} 款 · 共 ${totalQty} 件`;
        calcTotalBar.style.display = 'flex';
        metalToggle.style.display = '';
        calcEmpty.style.display = 'none';
        calcResults.style.display = '';
        let html = '';
        selected.forEach((qty, id) => {
          const m = productMeta.get(id);
          if (!m) return;
          html += `
            <div class="selected-item-card">
              <div class="sic-info">
                <div class="sic-name">${m.name}</div>
                <div class="sic-spec">${m.spec}</div>
              </div>
              <div class="sic-controls">
                <div class="qty-control">
                  <button type="button" class="qty-btn" data-action="dec" data-id="${id}">−</button>
                  <span class="qty-num">${qty}</span>
                  <button type="button" class="qty-btn" data-action="inc" data-id="${id}">+</button>
                </div>
                <button type="button" class="remove-btn" data-action="remove" data-id="${id}">×</button>
              </div>
            </div>`;
        });
        selectedList.innerHTML = html;
      }
      updateTotals();
    }

    // Metal toggle
    metalToggle.addEventListener('click', () => {
      metalsVisible = !metalsVisible;
      metalDetailL.style.display = metalsVisible ? '' : 'none';
      metalDetailR.style.display = metalsVisible ? '' : 'none';
      metalToggle.textContent = metalsVisible ? '收起材料明细' : '查看材料明细';
    });

    function updateTotals() {
      let co = 0, li = 0, ni = 0, mn = 0;
      let coR = 0, liR = 0, niR = 0, mnR = 0;
      let carbonLf = 0, waterLf = 0, ctueLf = 0;
      let carbonRc = 0, waterRc = 0, ctueRc = 0;
      selected.forEach((qty, id) => {
        const m = productMeta.get(id);
        if (!m) return;
        // Metals
        co += m.co * qty;
        li += m.li * qty;
        ni += m.ni * qty;
        mn += m.mn * qty;
        coR += m.co * (1 - m.recovery) * qty;
        liR += m.li * (1 - m.recovery) * qty;
        niR += m.ni * (1 - m.recovery) * qty;
        mnR += m.mn * (1 - m.recovery) * qty;
        // Carbon = production + disposal
        carbonLf += (m.carbon + m.carbonLf) * qty;
        carbonRc += (m.carbon + m.carbonRc) * qty;
        // Water = production + disposal
        waterLf += (m.water + m.waterLf) * qty;
        waterRc += (m.water + m.waterRc) * qty;
        ctueLf += m.ctueLf * qty;
        ctueRc += m.ctueRc * qty;
      });
      // Landfill
      sumCoL.textContent = co.toFixed(1);
      sumLiL.textContent = li.toFixed(1);
      sumNiL.textContent = ni.toFixed(1);
      sumMnL.textContent = mn.toFixed(1);
      sumCarbon.textContent = carbonLf.toFixed(1);
      document.getElementById('carbon-analogy-lf')!.textContent = `≈ 燃油车行驶约 ${Math.round(carbonLf * 8)} km`;
      // Recycle
      sumCoR.textContent = coR.toFixed(2);
      sumLiR.textContent = liR.toFixed(2);
      sumNiR.textContent = niR.toFixed(2);
      sumMnR.textContent = mnR.toFixed(2);
      sumCarbonR.textContent = carbonRc.toFixed(1);
      document.getElementById('carbon-analogy-rc')!.textContent = `≈ 燃油车行驶约 ${Math.round(carbonRc * 8)} km`;
      sumCtue.textContent = ctueLf.toFixed(1);
      sumCtueR.textContent = ctueRc.toFixed(2);
      document.getElementById('ctue-analogy-lf')!.textContent = `≈ 1000m³ 小池塘中约 ${(ctueLf * 0.8).toFixed(2)}% 水生物种承压 3 小时`;
      document.getElementById('ctue-analogy-rc')!.textContent = `≈ 1000m³ 小池塘中约 ${(ctueRc * 0.8).toFixed(2)}% 水生物种承压 3 小时`;
      document.getElementById('ctue-footnote')!.textContent = `假设单个池塘大小为 1000m³，同时该结果不代表实际死亡比例。`;

      // Animate pulse
      [sumCoL, sumLiL, sumNiL, sumMnL, sumCoR, sumLiR, sumNiR, sumMnR, sumCarbon, sumCarbonR].forEach(el => {
        el.classList.remove('pulse');
        void (el as HTMLElement).offsetWidth;
        el.classList.add('pulse');
      });
    }

    // Card click → toggle selection
    productCards.forEach(card => {
      card.addEventListener('click', () => {
        const id = (card as HTMLElement).dataset.id!;
        if (selected.has(id)) {
          selected.delete(id);
          card.classList.remove('selected');
        } else {
          selected.set(id, 1);
          card.classList.add('selected');
        }
        render();
      });
    });

    // Delegate clicks on selected items (inc, dec, remove)
    selectedList.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button') as HTMLButtonElement | null;
      if (!btn) return;
      const action = btn.dataset.action;
      const id = btn.dataset.id;
      if (!action || !id) return;
      if (action === 'inc') {
        selected.set(id, (selected.get(id) || 1) + 1);
      } else if (action === 'dec') {
        const qty = selected.get(id) || 1;
        if (qty <= 1) {
          selected.delete(id);
          const card = document.querySelector(`.product-card[data-id="${id}"]`);
          if (card) card.classList.remove('selected');
        } else {
          selected.set(id, qty - 1);
        }
      } else if (action === 'remove') {
        selected.delete(id);
        const card = document.querySelector(`.product-card[data-id="${id}"]`);
        if (card) card.classList.remove('selected');
      }
      render();
    });

    // Clear all
    clearBtn.addEventListener('click', () => {
      selected.clear();
      productCards.forEach(card => card.classList.remove('selected'));
      metalsVisible = false;
      metalDetailL.style.display = 'none';
      metalDetailR.style.display = 'none';
      metalToggle.textContent = '查看材料明细';
      render();
    });

    render();

    // BOM modal — open on card right-click or could be triggered from Reference
    const modal = document.getElementById('learn-modal')!;
    const modalTitle = document.getElementById('modal-title')!;
    const modalBody = document.getElementById('modal-body')!;
    const modalClose = document.getElementById('modal-close')!;

    function openModal(card: HTMLElement) {
      const name = card.dataset.name || '产品';
      const bomJson = card.dataset.bom || '[]';
      const bom = JSON.parse(bomJson);

      let bomHtml = '';
      if (bom.length > 0) {
        const rows = bom.map((r: any) =>
          `<tr><td>${r.cat}</td><td>${r.fn}</td><td>${r.brand||'—'}</td><td>${r.spec}</td><td>${r.pkg}</td><td>${r.qty}</td></tr>`
        ).join('');
        bomHtml = `
          <div class="bom-section">
            <div class="bom-title">物料清单</div>
            <div class="bom-table-wrap">
              <table class="bom-table">
                <thead><tr><th>类型</th><th>功能</th><th>品牌</th><th>规格</th><th>封装</th><th>数量</th></tr></thead>
                <tbody>${rows}</tbody>
              </table>
            </div>
          </div>`;
      }

      modalTitle.textContent = `${name} — 物料清单`;
      modalBody.innerHTML = (bom.length === 0)
        ? '<div style="color:#666;text-align:center;padding:40px;">暂无物料数据</div>'
        : bomHtml;
      modal.hidden = false;
    }

    function closeModal() {
      modal.hidden = true;
    }

    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });
  });
</script>
