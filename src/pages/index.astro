  /* Pulse animation for totals */
  @keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.08); color: var(--accent); }
    100% { transform: scale(1); }
  }

  .calc-value.pulse {
    animation: pulse 0.35s ease;
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .calc-hero {
      padding: 40px 0 36px;
      min-height: auto;
    }
    .calc-hero-title {
      font-size: 36px;
    }
    .hero-text {
      text-align: center;
      align-items: center;
    }
    .calc-hero-sub {
      max-width: 100%;
    }
    .scenario-cards {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 680px) {
    .product-select-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .calc-hero {
      padding: 32px 0 24px;
    }

    .calc-hero-title {
      font-size: 28px;
    }

    .calc-hero-sub {
      font-size: 14px;
    }

    .hero-cta, .hero-cta-secondary {
      padding: 12px 20px;
      font-size: 14px;
