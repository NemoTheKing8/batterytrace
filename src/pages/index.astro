  @media (max-width: 680px) {
    .modal-overlay {
      padding: 12px;
    }

    .modal-panel {
      max-height: 92vh;
      border-radius: 16px;
    }

    .modal-header {
      padding: 20px 20px 16px;
    }

    .modal-body {
      padding: 2px 20px 24px;
    }

    .info-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
